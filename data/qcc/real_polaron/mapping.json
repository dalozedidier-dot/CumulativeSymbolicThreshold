{
  "version": "1.1",
  "dataset": "polaron_real_polaron",
  "c_min": 0.35,
  "cq": {
    "source_col": "S(t)",
    "transform": "identity"
  },
  "o": {
    "method": "spectrum_band_integral",
    "u_imp_target": 2.5,
    "u_imp_selection": "closest",
    "u_imp_max_abs_delta_allowed": 0.25,
    "frequency_band": {
      "f_min": 0.0,
      "f_max": 2.851666666666667
    },
    "amplitude_col": "Amplitude",
    "frequency_col": "Frequency"
  },
  "r": {
    "definition": "constant",
    "value": 0.0
  },
  "sigma": {
    "definition": "cumulative_max0_o_minus_r",
    "time_col": "Time"
  }
}